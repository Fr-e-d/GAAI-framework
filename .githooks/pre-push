#!/usr/bin/env bash
# ── GAAI Pre-Push Hook ──────────────────────────────────────────────────
# Blocks all pushes to the production branch.
# AI agents must work exclusively on staging. Promotion to production
# is a human action via GitHub PR.
#
# Activate: git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────────────────────────

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/production" ]]; then
    echo ""
    echo "BLOCKED: Push to production is not allowed from this environment."
    echo "Use GitHub PR to promote staging → production."
    echo ""
    exit 1
  fi
done

exit 0
